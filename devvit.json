{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "cp-search",
  "post": {
    "dir": "public",
    "entrypoints": {
      "default": {
        "inline": true,
        "height": "regular",
        "entry": "splash.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "menu": {
    "items": [
      {
        "label": "Create Search Box Post",
        "description": "Create a search-focused app post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create/search-box"
      },
      {
        "label": "Create Episode Post",
        "description": "Create an episode post with metadata and links",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create/episode"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "forms": {
    "createEpisodeForm": "/internal/form/create-episode-form"
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "dev": {
    "subreddit": "cp_search_dev"
  }
}