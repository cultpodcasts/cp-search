{
  "private": true,
  "name": "cp-search",
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "build": "node --experimental-strip-types ./tools/build.ts --minify",
    "upload:private": "npm run build && devvit upload",
    "publish:public": "npm run build && devvit publish --public",
    "deploy": "npm run upload:private",
    "dev": "devvit playtest",
    "login": "devvit login",
    "launch": "npm run publish:public",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "dependencies": {
    "@devvit/web": "^0.12.14",
    "devvit": "^1.0.0",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "22.12.0",
    "esbuild": "0.27.2",
    "typescript": "5.9.3"
  }
}
